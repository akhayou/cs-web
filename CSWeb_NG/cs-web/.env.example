# ── Development ───────────────────────────────────────────────────────────────
# Leave VITE_API_BASE_URL empty in dev.
# Vite's proxy (vite.config.js) forwards /main and /session → http://localhost:81
# so there is NO CORS issue — the browser only ever talks to localhost:5173.
#
# VITE_API_BASE_URL=

# ── Production ────────────────────────────────────────────────────────────────
# Set this to your real backend URL when deploying.
# VITE_API_BASE_URL=https://your-api.example.com
